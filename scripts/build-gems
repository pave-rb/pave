#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

mkdir -p pkg

for spec in gems/*/*.gemspec; do
  echo "Building $spec..."
  gem_dir=$(dirname "$spec")
  gem_name=$(basename "$spec" .gemspec)
  (
    cd "$gem_dir"
    gem build "$gem_name.gemspec"
  )
  mv "$gem_dir/$gem_name"*.gem "$ROOT/pkg/"
done

echo "PASS: All gems built."
echo "Artifacts in pkg/:"
ls -1 pkg/
