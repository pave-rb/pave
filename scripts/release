#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

VERSION_FILE="gems/pave-core/lib/pave/version.rb"
CURRENT_VERSION=$(grep -oE '"[^"]+"' "$VERSION_FILE" | tr -d '"')

echo "Pavê release preparation"
echo "Current lockstep version: $CURRENT_VERSION"
echo

echo "Running repo cleanliness checks..."
if ! scripts/repo-check-clean; then
  echo "FAIL: Repository is not clean. Fix the reported issues before releasing."
  exit 1
fi

echo "Building gems..."
if ! scripts/build-gems; then
  echo "FAIL: Gem build failed. Fix the reported issues before releasing."
  exit 1
fi

echo "Release preparation complete for $CURRENT_VERSION."
echo "This script does not tag or publish. Next manual steps:"
echo "  1. Review pkg/*.gem artifacts"
echo "  2. Update CHANGELOG.md if needed"
echo "  3. Commit the release state"
echo "  4. git tag v$CURRENT_VERSION"
echo "  5. Push the tag to origin"
echo "  6. Publish gems to the internal registry (not RubyGems until public release is approved)"
