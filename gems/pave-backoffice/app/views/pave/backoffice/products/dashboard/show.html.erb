<div class="space-y-10">
  <div class="rounded-lg border border-indigo-400/30 bg-indigo-950/30 p-5">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <p class="text-xs font-semibold uppercase tracking-wide text-indigo-300">Product context</p>
        <h1 class="mt-1 text-2xl font-bold tracking-tight text-white"><%= @product.label %></h1>
        <p class="mt-1 text-sm text-slate-400">Runtime product administration for <code class="rounded bg-slate-800 px-1 py-0.5 text-slate-300"><%= @product.key %></code>.</p>
      </div>
      <span class="rounded-full border border-indigo-300/40 px-3 py-1 text-xs font-medium text-indigo-100">Product</span>
    </div>
    <p class="mt-4 rounded-md border border-slate-700 bg-slate-900/70 px-3 py-2 text-sm text-slate-300">
      No tenant space is active in backoffice.
    </p>
  </div>

  <section>
    <h2 class="text-lg font-semibold text-white">Product status</h2>
    <div class="mt-3 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <div class="rounded-lg border border-slate-700 bg-slate-800 p-4">
        <p class="text-xs uppercase tracking-wide text-slate-500">Mode</p>
        <p class="mt-1 text-sm font-medium text-slate-200"><%= @product.mode.to_s.humanize %></p>
      </div>
      <div class="rounded-lg border border-slate-700 bg-slate-800 p-4">
        <p class="text-xs uppercase tracking-wide text-slate-500">Root</p>
        <p class="mt-1 truncate text-sm font-medium text-slate-200"><%= @product.root %></p>
      </div>
      <div class="rounded-lg border border-slate-700 bg-slate-800 p-4">
        <p class="text-xs uppercase tracking-wide text-slate-500">Registered panels</p>
        <p class="mt-1 text-sm font-medium text-slate-200"><%= pluralize(@product_panels.size + @plugin_panels.size, "panel") %></p>
      </div>
    </div>
  </section>

  <section>
    <h2 class="text-lg font-semibold text-white">Registered panels</h2>
    <% if @product_panels.any? %>
      <div class="mt-3 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <% @product_panels.each do |panel| %>
          <article class="rounded-lg border border-slate-700 bg-slate-800 p-4">
            <h3 class="font-medium text-white"><%= panel.label %></h3>
            <% if panel.description.present? %>
              <p class="mt-1 text-sm text-slate-400"><%= panel.description %></p>
            <% end %>
            <p class="mt-3 text-xs text-slate-500">/admin/<%= @product.key %>/<%= panel.slug %></p>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="mt-3">
        <%= render "pave/backoffice/components/empty_state",
              variant: :missing_configuration,
              title: "No backoffice panels registered",
              description: "This product is registered, but it has not declared product backoffice panels.",
              action: ["Add products/:product/config/backoffice.rb", "#"],
              secondary_action: ["Run bin/pave doctor", "#"] %>
      </div>
    <% end %>
  </section>

  <section>
    <h2 class="text-lg font-semibold text-white">Plugin panels</h2>
    <% if @plugin_panels.any? %>
      <div class="mt-3 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <% @plugin_panels.each do |panel| %>
          <article class="rounded-lg border border-slate-700 bg-slate-800 p-4">
            <h3 class="font-medium text-white"><%= panel.label %></h3>
            <p class="mt-1 text-xs text-slate-500"><%= panel.source_package.presence || "Plugin" %></p>
          </article>
        <% end %>
      </div>
    <% else %>
      <p class="mt-3 text-sm text-slate-500 italic">No plugin panels registered for this product.</p>
    <% end %>
  </section>

  <section class="grid gap-4 lg:grid-cols-2">
    <div class="rounded-lg border border-slate-700 bg-slate-800 p-4">
      <h2 class="text-lg font-semibold text-white">Product settings health</h2>
      <p class="mt-2 text-sm text-slate-400">Product settings declarations remain product-owned and are not loaded as tenant scope.</p>
    </div>
    <div class="rounded-lg border border-slate-700 bg-slate-800 p-4">
      <h2 class="text-lg font-semibold text-white">Product-level diagnostics</h2>
      <p class="mt-2 text-sm text-slate-400">Run <code class="rounded bg-slate-700 px-1 py-0.5 text-slate-300">bin/pave doctor</code> to validate product backoffice registrations.</p>
    </div>
  </section>

  <section>
    <h2 class="text-lg font-semibold text-white">Recent product audit events</h2>
    <% if @recent_audit_events.any? %>
      <div class="mt-3 overflow-hidden rounded-lg border border-slate-700">
        <table class="min-w-full divide-y divide-slate-700">
          <thead class="bg-slate-800">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-slate-400">Time</th>
              <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-slate-400">Event</th>
              <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-slate-400">Actor</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-700 bg-slate-800/50">
            <% @recent_audit_events.each do |event| %>
              <tr>
                <td class="whitespace-nowrap px-4 py-2 text-sm text-slate-300"><%= l(event.occurred_at, format: :short) rescue event.occurred_at.to_fs(:db) %></td>
                <td class="whitespace-nowrap px-4 py-2 text-sm text-slate-300"><code class="rounded bg-slate-700 px-1 py-0.5 text-xs"><%= event.key %></code></td>
                <td class="whitespace-nowrap px-4 py-2 text-sm text-slate-300"><%= event.actor_label || "Backoffice" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="mt-3 text-sm text-slate-500 italic">No recent product audit events.</p>
    <% end %>
  </section>
</div>
