<h1 class="text-2xl font-semibold tracking-tight">Sign in</h1>
<p class="mt-1 text-sm text-slate-500">Platform administration access</p>

<% if flash.any? %>
  <div class="my-4 space-y-2">
    <% flash.each do |type, message| %>
      <% tone = type.to_s == "alert" ? "text-red-600" : "text-green-600" %>
      <div class="<%= tone %>"><%= message %></div>
    <% end %>
  </div>
<% end %>

<%= form_with(url: pave_backoffice.session_path, local: true, class: "mt-8 space-y-5") do |f| %>
  <div>
    <%= f.label :email, class: "block text-sm font-medium text-slate-700" %>
    <%= f.email_field :email, required: true, autofocus: true, autocomplete: "email",
                      class: "mt-1 block w-full rounded-lg border border-slate-300 px-3 py-2 shadow-sm placeholder:text-slate-400 focus:border-electric focus:outline-none focus:ring-1 focus:ring-electric" %>
  </div>
  <div>
    <%= f.label :password, class: "block text-sm font-medium text-slate-700" %>
    <%= f.password_field :password, required: true, autocomplete: "current-password",
                         class: "mt-1 block w-full rounded-lg border border-slate-300 px-3 py-2 shadow-sm placeholder:text-slate-400 focus:border-electric focus:outline-none focus:ring-1 focus:ring-electric" %>
  </div>
  <%= f.submit "Sign in",
               class: "w-full rounded-lg bg-deep px-4 py-2.5 text-sm font-medium text-white hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-electric focus:ring-offset-2" %>
<% end %>
