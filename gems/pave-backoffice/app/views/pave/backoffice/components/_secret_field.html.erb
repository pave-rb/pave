<% name = local_assigns.fetch(:name) %>
<% id = local_assigns.fetch(:id, name.to_s.parameterize.underscore) %>
<% label = local_assigns.fetch(:label, name.to_s.humanize) %>
<% value_present = local_assigns.fetch(:value_present, false) %>
<% source = local_assigns.fetch(:source, :missing) %>
<% required = local_assigns.fetch(:required, false) %>
<% placeholder = local_assigns.fetch(:placeholder, value_present ? "Leave blank to keep existing secret" : "Enter secret") %>
<% errors = local_assigns.fetch(:errors, []) %>
<% hint = local_assigns[:hint] %>
<% clearable = local_assigns.fetch(:clearable, source == :database) %>
<% data = local_assigns.fetch(:data, {}).merge(backoffice_secret_field: true) %>

<div class="rounded-lg border border-slate-700 bg-slate-900/40 p-4"
     data-controller="pave--backoffice--secret-field"
     data-pave--backoffice--secret-field-source-value="<%= source %>"
     data-pave--backoffice--secret-field-present-value="<%= value_present.to_s %>"
     <% data.each do |key, value| %> data-<%= key.to_s.dasherize %>="<%= value %>"<% end %>>
  <div class="flex flex-wrap items-start justify-between gap-3">
    <div>
      <%= label_tag id, label, class: "block text-sm font-medium text-white" %>
      <p class="mt-1 text-xs text-slate-500">
        <%= secret_field_type_label(source, required) %>
      </p>
    </div>
    <span class="rounded-full bg-slate-700 px-2 py-0.5 text-xs text-slate-300" data-pave--backoffice--secret-field-target="sourceBadge">
      <%= source.to_s.humanize %>
    </span>
  </div>

  <div class="mt-3">
    <div class="flex items-center gap-2 rounded-md border border-slate-700 bg-slate-800 px-3 py-2 text-sm text-slate-300">
      <span class="flex-1 truncate" data-pave--backoffice--secret-field-target="maskedValue" aria-label="Secret value is masked">
        <%= value_present ? "••••••••" : "Not set" %>
      </span>

      <% if value_present %>
        <button type="button"
                data-action="pave--backoffice--secret-field#reveal"
                data-pave--backoffice--secret-field-target="revealButton"
                class="rounded border border-slate-600 px-2 py-1 text-xs text-slate-300 hover:bg-slate-700 hover:text-white transition">
          Reveal
        </button>
      <% end %>

      <button type="button"
              data-action="pave--backoffice--secret-field#copy"
              data-pave--backoffice--secret-field-target="copyButton"
              data-copied-text="Copied"
              class="rounded border border-slate-600 px-2 py-1 text-xs text-slate-300 hover:bg-slate-700 hover:text-white transition"
              <%= "disabled" unless value_present %>>
        Copy
      </button>
    </div>
  </div>

  <details class="mt-3 group">
    <summary class="cursor-pointer text-sm text-electric hover:underline" data-action="click->pave--backoffice--secret-field#openEdit">
      Edit replacement value
    </summary>

    <div class="mt-3">
      <%= password_field_tag name, nil,
            id: id,
            autocomplete: "new-password",
            placeholder: placeholder,
            data: { "pave--backoffice--secret-field-target" => "input" },
            class: "w-full rounded-md border border-slate-700 bg-slate-800 px-3 py-2 text-sm text-white placeholder-slate-500 focus:border-electric focus:outline-none focus:ring-1 focus:ring-electric" %>

      <% if hint.present? %>
        <p class="mt-2 text-xs text-slate-500"><%= hint %></p>
      <% end %>
    </div>
  </details>

  <% if clearable %>
    <label class="mt-3 flex items-start gap-2 text-xs text-slate-300">
      <%= check_box_tag "clear_settings[]", name.to_s.sub(/\Asettings\[(.*)\]\z/, '\\1'), false,
            data: { "pave--backoffice--secret-field-target" => "clear", action: "change->pave--backoffice--secret-field#toggleClear" },
            class: "mt-0.5 rounded border-slate-600 bg-slate-700 text-electric focus:ring-electric" %>
      <span>Clear stored secret on save.</span>
    </label>
  <% end %>

  <% if errors.any? %>
    <p class="mt-2 text-xs text-red-300"><%= errors.to_sentence %></p>
  <% end %>
</div>
