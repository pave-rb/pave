<h1 class="text-2xl font-semibold tracking-tight"><%= t("mfa.totp_enrollment.title") %></h1>
<p class="mt-1 text-sm text-slate-500"><%= t("mfa.totp_enrollment.subtitle") %></p>

<% if flash.any? %>
  <div class="my-4 space-y-2">
    <% flash.each do |type, message| %>
      <% tone = type.to_s == "alert" ? "text-red-600" : "text-green-600" %>
      <div class="<%= tone %>"><%= message %></div>
    <% end %>
  </div>
<% end %>

<div class="mt-6">
  <%= render "pave/backoffice/mfa/passkey_panel",
        title: t("mfa.passkeys.register_title"),
        subtitle: t("mfa.passkeys.register_subtitle"),
        button_text: t("mfa.passkeys.register"),
        action_name: :register,
        show_label: true,
        options_url: registration_options_mfa_passkeys_path,
        submit_url: mfa_passkeys_path %>
</div>

<div class="mt-6 flex items-center gap-3 text-xs uppercase tracking-[0.2em] text-slate-400">
  <span class="h-px flex-1 bg-slate-200"></span>
  <span><%= t("mfa.totp_enrollment.alternative_divider") %></span>
  <span class="h-px flex-1 bg-slate-200"></span>
</div>

<div class="mt-6 grid gap-6 md:grid-cols-[220px_minmax(0,1fr)] md:items-start">
  <div class="flex items-center justify-center rounded-2xl border border-slate-200 bg-white p-4">
    <%= raw(@qr_code_svg) %>
  </div>

  <div class="space-y-4">
    <div class="rounded-2xl border border-slate-200 bg-slate-50/80 p-4">
      <p class="text-xs font-semibold uppercase tracking-wide text-slate-500"><%= t("mfa.totp_enrollment.secret_label") %></p>
      <p class="mt-2 break-all font-mono text-sm text-deep"><%= @provisioning_secret %></p>
    </div>

    <%= form_with(url: mfa_totp_enrollment_path, local: true, class: "space-y-4") do |f| %>
      <div>
        <%= f.label :code, t("mfa.totp_enrollment.code_label"), class: "block text-sm font-medium text-slate-700" %>
        <%= f.text_field :code, autocomplete: "one-time-code", inputmode: "numeric", class: "mt-1 block w-full rounded-lg border border-slate-300 px-3 py-2 shadow-sm placeholder:text-slate-400 focus:border-electric focus:outline-none focus:ring-1 focus:ring-electric", maxlength: 6 %>
      </div>
      <%= f.submit t("mfa.totp_enrollment.submit"), class: "w-full rounded-lg bg-deep px-4 py-2.5 text-sm font-medium text-white hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-electric focus:ring-offset-2" %>
    <% end %>
  </div>
</div>
