<h1 class="text-2xl font-semibold tracking-tight">MFA Challenge</h1>
<p class="mt-1 text-sm text-slate-500">Enter your authentication code to continue to the admin panel.</p>

<% if flash.any? %>
  <div class="my-4 space-y-2">
    <% flash.each do |type, message| %>
      <% tone = type.to_s == "alert" ? "text-red-600" : "text-green-600" %>
      <div class="<%= tone %>"><%= message %></div>
    <% end %>
  </div>
<% end %>

<% if @passkeys_enabled %>
  <div class="mt-8">
    <%= render "pave/backoffice/mfa/passkey_panel",
          title: t("mfa.passkeys.authenticate_title"),
          subtitle: t("mfa.passkeys.authenticate_subtitle"),
          button_text: t("mfa.passkeys.authenticate"),
          action_name: :authenticate,
          show_label: false,
          options_url: authentication_options_mfa_passkeys_path,
          submit_url: authenticate_mfa_passkeys_path %>
  </div>

  <div class="mt-6 flex items-center gap-3 text-xs uppercase tracking-[0.2em] text-slate-400">
    <span class="h-px flex-1 bg-slate-200"></span>
    <span><%= t("mfa.challenge.passkey_divider") %></span>
    <span class="h-px flex-1 bg-slate-200"></span>
  </div>
<% end %>

<%= form_with(url: mfa_challenge_path, local: true, class: "mt-8 space-y-5") do |f| %>
  <div>
    <%= f.label :otp_attempt, t("mfa.challenge.otp_label"), class: "block text-sm font-medium text-slate-700" %>
    <%= f.text_field :otp_attempt, autocomplete: "one-time-code", inputmode: "numeric", class: "mt-1 block w-full rounded-lg border border-slate-300 px-3 py-2 shadow-sm placeholder:text-slate-400 focus:border-electric focus:outline-none focus:ring-1 focus:ring-electric", maxlength: 6 %>
  </div>
  <%= f.submit t("mfa.challenge.submit"), class: "w-full rounded-lg bg-deep px-4 py-2.5 text-sm font-medium text-white hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-electric focus:ring-offset-2" %>
<% end %>

<div class="mt-6 flex items-center gap-3 text-xs uppercase tracking-[0.2em] text-slate-400">
  <span class="h-px flex-1 bg-slate-200"></span>
  <span><%= t("mfa.challenge.recovery_divider") %></span>
  <span class="h-px flex-1 bg-slate-200"></span>
</div>

<%= form_with(url: mfa_challenge_path, local: true, class: "mt-4 space-y-5") do |f| %>
  <div>
    <%= f.label :recovery_code_attempt, t("mfa.challenge.recovery_code_label"), class: "block text-sm font-medium text-slate-700" %>
    <%= f.text_field :recovery_code_attempt, autocomplete: "one-time-code", class: "mt-1 block w-full rounded-lg border border-slate-300 px-3 py-2 shadow-sm placeholder:text-slate-400 focus:border-electric focus:outline-none focus:ring-1 focus:ring-electric" %>
  </div>
  <%= f.submit t("mfa.challenge.recovery_submit"), class: "w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm font-medium text-slate-700 hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-electric focus:ring-offset-2" %>
<% end %>
