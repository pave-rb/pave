<%= render "pave/backoffice/components/secret_field",
      name: "settings[#{definition.key}]",
      id: "settings_#{definition.key}",
      label: definition.key.to_s.humanize,
      value_present: status.present?,
      source: status.source,
      required: definition.required,
      placeholder: status.present? ? "Leave blank to keep existing secret" : "Enter secret",
      errors: errors,
      clearable: status.source == :database %>
