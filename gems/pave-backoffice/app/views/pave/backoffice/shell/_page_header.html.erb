<header class="rounded-lg border border-slate-800 bg-slate-900/70 p-5" data-backoffice-page-header>
  <div class="flex flex-wrap items-start justify-between gap-4">
    <div>
      <p class="text-xs font-semibold uppercase tracking-wider text-slate-500"><%= backoffice_page_scope_label %></p>
      <h1 class="mt-1 text-2xl font-bold tracking-tight text-white"><%= backoffice_page_title %></h1>
      <% if backoffice_page_description.present? %>
        <p class="mt-1 max-w-3xl text-sm text-slate-400"><%= backoffice_page_description %></p>
      <% end %>
    </div>

    <%= render "pave/backoffice/components/context_badge",
          variant: backoffice_current_product ? :product : :platform,
          label: backoffice_current_product ? [backoffice_current_product.label, backoffice_current_panel&.label].compact.join(" · ") : nil,
          data: { backoffice_page_context: true } %>
  </div>
</header>
