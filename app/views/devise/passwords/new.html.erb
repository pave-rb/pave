<div class="min-h-screen flex items-center justify-center">
  <div class="max-w-md w-full card-solid p-8">
    <h2 class="font-display text-2xl font-extrabold text-deep tracking-tight text-center mb-2">
      <%= t("devise.passwords.new.title") %>
    </h2>

    <p class="mb-6 text-center text-sm text-slate-600">
      <%= t("devise.passwords.new.subtitle") %>
    </p>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="mb-6">
        <%= f.label :email, t("devise.passwords.new.email"), class: form_label_classes %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: form_input_classes %>
      </div>

      <div>
        <%= f.submit t("devise.passwords.new.submit"),
                     class: "#{button_classes(:primary)} w-full",
                     data: { turbo_submits_with: t("devise.passwords.submit_loading") } %>
      </div>
    <% end %>

    <div class="mt-6 flex flex-col items-center gap-2 text-center text-sm text-slate-600">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
