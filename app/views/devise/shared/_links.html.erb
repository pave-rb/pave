<%- if controller_name != 'sessions' %>
  <p>
    <%= link_to t("devise.shared.links.sign_in"),
                new_session_path(resource_name),
                class: "text-sm font-medium text-slate-900 hover:underline" %>
  </p>
<% end %>

<%- if registrations_enabled? && devise_mapping.registerable? && controller_name != 'registrations' %>
  <p>
    <%= link_to t("devise.shared.links.sign_up"),
                new_registration_path(resource_name),
                class: "text-sm font-medium text-slate-900 hover:underline" %>
  </p>
<% end %>

<%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
  <p>
    <%= link_to t("devise.shared.links.forgot_password"),
                new_password_path(resource_name),
                class: "text-sm font-medium text-slate-900 hover:underline" %>
  </p>
<% end %>

<%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
  <p>
    <%= link_to t("devise.shared.links.confirmation"),
                new_confirmation_path(resource_name),
                class: "text-sm font-medium text-slate-900 hover:underline" %>
  </p>
<% end %>

<%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
  <p>
    <%= link_to t("devise.shared.links.unlock"),
                new_unlock_path(resource_name),
                class: "text-sm font-medium text-slate-900 hover:underline" %>
  </p>
<% end %>

<% providers = resource_class.omniauth_providers.select { |provider| Devise.omniauth_configs.key?(provider) } %>
<%- if providers.any? %>
  <%- providers.each do |provider| %>
    <p>
      <%= button_to t("devise.shared.links.omniauth", provider: OmniAuth::Utils.camelize(provider)),
                    omniauth_authorize_path_for(resource_name, provider),
                    class: "#{button_classes(:secondary)} w-full justify-center",
                    data: { turbo: false } %>
    </p>
  <% end %>
<% end %>
