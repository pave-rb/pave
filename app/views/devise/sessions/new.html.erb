<div class="min-h-screen flex items-center justify-center">
  <div class="max-w-md w-full card-solid p-8">
    <h2 class="font-display text-2xl font-extrabold text-deep tracking-tight text-center mb-6">
      <%= t("devise.sessions.title") %>
    </h2>

    <%= render "devise/shared/social_buttons",
               resource_name: resource_name,
               resource_class: resource_class,
               variant: :sign_in %>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="mb-4">
        <%= f.label :email, t("devise.sessions.email"), class: form_label_classes %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: form_input_classes %>
      </div>

      <div class="mb-4">
        <%= f.label :password, t("devise.sessions.password"), class: form_label_classes %>
        <%= f.password_field :password, autocomplete: "current-password", class: form_input_classes %>
      </div>

      <div class="flex items-center justify-between mb-6">
        <div class="flex items-center">
          <%= f.check_box :remember_me, class: "h-4 w-4 text-electric" %>
          <%= f.label :remember_me, t("devise.sessions.remember_me"), class: "ml-2 block text-sm text-deep" %>
        </div>
        <%= link_to t("devise.sessions.forgot_password_link"), new_password_path(resource_name),
                    class: "text-sm text-electric hover:underline" %>
      </div>

      <div>
        <%= f.submit t("devise.sessions.sign_in_button"), class: "#{button_classes(:primary)} w-full", data: { turbo_submits_with: t("devise.sessions.submit_loading") } %>
      </div>
    <% end %>

    <% if registrations_enabled? %>
      <p class="mt-6 text-center text-sm text-slate-600">
        <%= t("devise.sessions.no_account") %>
        <%= link_to t("devise.sessions.sign_up_link"), new_registration_path(resource_name),
                    class: "text-slate-900 font-medium hover:underline" %>
      </p>
    <% end %>
  </div>
</div>
