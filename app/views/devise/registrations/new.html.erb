<div class="min-h-screen flex items-center justify-center">
  <div class="max-w-md w-full card-solid p-8">
    <h2 class="font-display text-2xl font-extrabold text-deep tracking-tight text-center mb-6">
      <%= t("devise.registrations.title") %>
    </h2>

    <%= render "devise/shared/social_buttons",
               resource_name: resource_name,
               resource_class: resource_class,
               variant: :sign_up %>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <% if f.object.respond_to?(:name) %>
        <div class="mb-4">
          <%= f.label :name, t("devise.registrations.name"), class: form_label_classes %>
          <%= f.text_field :name, class: form_input_classes %>
        </div>
      <% end %>

      <div class="mb-4">
        <%= f.label :email, t("devise.registrations.email"), class: form_label_classes %>
        <%= f.email_field :email, class: form_input_classes %>
      </div>

      <div class="mb-4">
        <%= f.label :phone_number, t("devise.registrations.phone_number"), class: form_label_classes %>
        <%= f.telephone_field :phone_number, autocomplete: "tel", class: form_input_classes %>
      </div>

      <div class="mb-4">
        <%= f.label :password, t("devise.registrations.password"), class: form_label_classes %>
        <%= f.password_field :password, autocomplete: "new-password", class: form_input_classes %>
      </div>

      <div class="mb-4 rounded-2xl border border-slate-200 bg-slate-50/80 p-4">
        <p class="mb-3 text-sm text-slate-600"><%= t("devise.registrations.legal_required") %></p>

        <label class="flex items-start gap-3 text-sm text-slate-700">
          <%= f.check_box :accept_terms_of_service, required: true, class: "mt-1 rounded border-slate-300 text-electric focus:ring-electric" %>
          <span>
            <%= t(
              "devise.registrations.accept_terms_html",
              terms_link: link_to(
                t("legal.terms_of_service.title"),
                terms_of_service_path,
                class: "font-medium text-deep hover:underline",
                target: "_blank",
                rel: "noopener"
              ),
              version: Legal::DocumentCatalog.fetch(:terms_of_service).version
            ) %>
          </span>
        </label>

        <label class="mt-3 flex items-start gap-3 text-sm text-slate-700">
          <%= f.check_box :accept_privacy_policy, required: true, class: "mt-1 rounded border-slate-300 text-electric focus:ring-electric" %>
          <span>
            <%= t(
              "devise.registrations.accept_privacy_html",
              privacy_link: link_to(
                t("legal.privacy_policy.title"),
                privacy_policy_path,
                class: "font-medium text-deep hover:underline",
                target: "_blank",
                rel: "noopener"
              ),
              version: Legal::DocumentCatalog.fetch(:privacy_policy).version
            ) %>
          </span>
        </label>
      </div>

      <div>
        <%= f.submit t("devise.registrations.sign_up_button"), class: button_classes(:primary) + " w-full", data: { turbo_submits_with: t("devise.registrations.submit_loading") } %>
        <p class="mt-2 text-center text-sm text-slate-600">
          <%= t("devise.registrations.trial_message") %>
        </p>
      </div>
    <% end %>

    <p class="mt-6 text-center text-sm text-slate-600">
      <%= t("devise.registrations.already_account") %>
      <%= link_to t("devise.registrations.sign_in_link"), new_session_path(resource_name),
                  class: "text-slate-900 font-medium hover:underline" %>
    </p>
  </div>
</div>
