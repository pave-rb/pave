<% url = edit_password_url(@resource, reset_password_token: @token) %>
<% content_for :email_preheader, t("devise.mailer.email_content.reset_password_instructions.preheader") %>
<% content_for :email_eyebrow, t("mailers.shared.eyebrows.security") %>
<% content_for :email_title, t("devise.mailer.email_content.reset_password_instructions.title") %>
<% content_for :email_intro, t("devise.mailer.email_content.reset_password_instructions.intro", email: @resource.email) %>
<% content_for :email_cta_label, t("devise.mailer.email_content.reset_password_instructions.cta") %>
<% content_for :email_cta_url, url %>

<p style="margin: 0 0 16px;"><%= t("devise.mailer.email_content.reset_password_instructions.greeting", email: @resource.email) %></p>

<%= render "shared/mailer/callout",
           title: t("devise.mailer.email_content.reset_password_instructions.callout_title"),
           tone: "warning",
           content: t("devise.mailer.email_content.reset_password_instructions.body") %>
