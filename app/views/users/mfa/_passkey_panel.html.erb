<div data-controller="passkey"
     data-passkey-options-url-value="<%= options_url %>"
     data-passkey-submit-url-value="<%= submit_url %>"
     data-passkey-unsupported-message-value="<%= t('mfa.passkeys.errors.unsupported_browser') %>"
     data-passkey-generic-error-message-value="<%= t('mfa.passkeys.errors.generic') %>"
     data-passkey-label-required-message-value="<%= t('mfa.passkeys.errors.label_blank') %>"
     class="rounded-3xl border border-slate-200 bg-white/90 p-5 space-y-4 shadow-sm">
  <div>
    <p class="meta-label-strong"><%= title %></p>
    <p class="mt-2 text-sm text-slate-600"><%= subtitle %></p>
  </div>

  <% if show_label %>
    <div>
      <%= label_tag :passkey_label, t("mfa.passkeys.label"), class: form_label_classes %>
      <%= text_field_tag :passkey_label,
                         nil,
                         class: form_input_classes,
                         placeholder: t("mfa.passkeys.label_placeholder"),
                         data: { passkey_target: "label" } %>
    </div>
  <% end %>

  <div data-passkey-target="error"
       class="hidden rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700"></div>

  <button type="button"
          data-passkey-action="<%= action_name %>"
          data-action="passkey#<%= action_name %>"
          data-passkey-target="button"
          data-register-loading-text="<%= t('mfa.passkeys.register_loading') %>"
          data-authenticate-loading-text="<%= t('mfa.passkeys.authenticate_loading') %>"
          class="<%= button_classes(:secondary) %> w-full justify-center">
    <%= button_text %>
  </button>
</div>
