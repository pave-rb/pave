<div class="min-h-screen flex items-center justify-center">
  <div class="max-w-xl w-full card-solid p-8 space-y-6">
    <div class="text-center">
      <h2 class="font-display text-2xl font-extrabold text-deep tracking-tight">
        <%= t("mfa.totp_enrollment.title") %>
      </h2>
      <p class="mt-2 text-sm text-slate-600"><%= t("mfa.totp_enrollment.subtitle") %></p>
    </div>

    <% if flash.now[:alert].present? || flash[:alert].present? %>
      <div class="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
        <%= flash.now[:alert].presence || flash[:alert] %>
      </div>
    <% end %>

    <%= render "users/mfa/passkey_panel",
               title: t("mfa.passkeys.register_title"),
               subtitle: t("mfa.passkeys.register_subtitle"),
               button_text: t("mfa.passkeys.register"),
               action_name: :register,
               show_label: true,
               options_url: registration_options_user_mfa_passkeys_path,
               submit_url: user_mfa_passkeys_path %>

    <div class="flex items-center gap-3 text-xs uppercase tracking-[0.2em] text-slate-400">
      <span class="h-px flex-1 bg-slate-200"></span>
      <span><%= t("mfa.totp_enrollment.alternative_divider") %></span>
      <span class="h-px flex-1 bg-slate-200"></span>
    </div>

    <div class="grid gap-6 md:grid-cols-[220px_minmax(0,1fr)] md:items-start">
      <div class="rounded-2xl border border-slate-200 bg-white p-4 flex items-center justify-center">
        <%= raw(@qr_code_svg) %>
      </div>

      <div class="space-y-4">
        <div class="rounded-2xl border border-slate-200 bg-slate-50/80 p-4">
          <p class="meta-label-strong"><%= t("mfa.totp_enrollment.secret_label") %></p>
          <p class="mt-2 font-mono text-sm text-deep break-all"><%= @provisioning_secret %></p>
        </div>

        <%= form_with url: user_mfa_totp_enrollment_path, class: "space-y-4" do |form| %>
          <div>
            <%= form.label :code, t("mfa.totp_enrollment.code_label"), class: form_label_classes %>
            <%= form.text_field :code,
                                autocomplete: "one-time-code",
                                inputmode: "numeric",
                                class: form_input_classes,
                                maxlength: 6 %>
          </div>

          <%= form.submit t("mfa.totp_enrollment.submit"), class: button_classes(:primary), data: { turbo_submits_with: t("mfa.totp_enrollment.submit_loading") } %>
        <% end %>
      </div>
    </div>
  </div>
</div>
