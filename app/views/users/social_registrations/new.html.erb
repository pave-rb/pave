<div class="min-h-screen flex items-center justify-center">
  <div class="max-w-md w-full card-solid p-8">
    <h2 class="font-display text-2xl font-extrabold text-deep tracking-tight text-center mb-2">
      <%= t("social_registrations.new.title", provider: provider_name) %>
    </h2>

    <p class="mb-6 text-center text-sm text-slate-600">
      <%= t("social_registrations.new.subtitle", provider: provider_name) %>
    </p>

    <%= form_with model: @user, scope: :user, url: user_social_registration_path do |f| %>
      <%= render "devise/shared/error_messages", resource: @user %>

      <div class="mb-4">
        <%= f.label :name, t("social_registrations.new.name"), class: form_label_classes %>
        <%= f.text_field :name, class: form_input_classes %>
      </div>

      <div class="mb-4">
        <%= f.label :email, t("social_registrations.new.email"), class: form_label_classes %>
        <%= f.email_field :email, readonly: true, class: form_input_classes("bg-slate-100 cursor-not-allowed") %>
      </div>

      <div class="mb-4">
        <%= f.label :phone_number, t("social_registrations.new.phone_number"), class: form_label_classes %>
        <%= f.telephone_field :phone_number, autocomplete: "tel", required: true, class: form_input_classes %>
      </div>

      <div class="mb-4 rounded-2xl border border-slate-200 bg-slate-50/80 p-4">
        <p class="mb-3 text-sm text-slate-600"><%= t("devise.registrations.legal_required") %></p>

        <label class="flex items-start gap-3 text-sm text-slate-700">
          <%= f.check_box :accept_terms_of_service, required: true, class: "mt-1 rounded border-slate-300 text-electric focus:ring-electric" %>
          <span>
            <%= t(
              "devise.registrations.accept_terms_html",
              terms_link: link_to(
                t("legal.terms_of_service.title"),
                terms_of_service_path,
                class: "font-medium text-deep hover:underline",
                target: "_blank",
                rel: "noopener"
              ),
              version: Legal::DocumentCatalog.fetch(:terms_of_service).version
            ) %>
          </span>
        </label>

        <label class="mt-3 flex items-start gap-3 text-sm text-slate-700">
          <%= f.check_box :accept_privacy_policy, required: true, class: "mt-1 rounded border-slate-300 text-electric focus:ring-electric" %>
          <span>
            <%= t(
              "devise.registrations.accept_privacy_html",
              privacy_link: link_to(
                t("legal.privacy_policy.title"),
                privacy_policy_path,
                class: "font-medium text-deep hover:underline",
                target: "_blank",
                rel: "noopener"
              ),
              version: Legal::DocumentCatalog.fetch(:privacy_policy).version
            ) %>
          </span>
        </label>
      </div>

      <div>
        <%= f.submit t("social_registrations.new.submit"),
                     class: "#{button_classes(:primary)} w-full",
                     data: { turbo_submits_with: t("social_registrations.new.submit_loading") } %>
      </div>
    <% end %>

    <p class="mt-6 text-center text-sm text-slate-600">
      <%= link_to t("social_registrations.new.back_to_sign_in"),
                  new_user_session_path,
                  class: "text-slate-900 font-medium hover:underline" %>
    </p>
  </div>
</div>
