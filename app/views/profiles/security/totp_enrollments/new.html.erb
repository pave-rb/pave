<% content_for(:settings_sidebar) do %>
  <%= render "shared/account_settings_sidebar" %>
<% end %>

<div class="space-y-6">
  <%= render "shared/settings_intro",
             eyebrow: t("account.sidebar.security"),
             title: t("mfa.totp_enrollment.title"),
             subtitle: t("mfa.totp_enrollment.subtitle"),
             statuses: [
               settings_intro_status(t("profiles.security.totp.title"), t("profiles.security.status.pending"), tone: :accent)
             ] %>

  <%= form_with url: profile_security_totp_enrollment_path, class: "space-y-6" do |form| %>
    <%= render "shared/settings_panel" do %>
      <div class="space-y-6">
        <% if flash.now[:alert].present? || flash[:alert].present? %>
          <div class="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
            <%= flash.now[:alert].presence || flash[:alert] %>
          </div>
        <% end %>

        <div class="grid gap-6 md:grid-cols-[220px_minmax(0,1fr)] md:items-start">
          <div class="rounded-2xl border border-slate-200 bg-white p-4 flex items-center justify-center">
            <%= raw(@qr_code_svg) %>
          </div>

          <div class="space-y-4">
            <div class="settings-info-tile">
              <p class="meta-label-strong"><%= t("mfa.totp_enrollment.secret_label") %></p>
              <p class="mt-2 font-mono text-sm text-deep break-all"><%= @provisioning_secret %></p>
            </div>

            <div>
              <%= form.label :code, t("mfa.totp_enrollment.code_label"), class: form_label_classes %>
              <%= form.text_field :code,
                                  autocomplete: "one-time-code",
                                  inputmode: "numeric",
                                  class: form_input_classes,
                                  maxlength: 6 %>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <%= render "shared/settings_action_bar", reveal_mode: :dirty do %>
      <%= form.submit t("mfa.totp_enrollment.submit"),
                      class: "#{button_classes(:primary)} w-full justify-center lg:w-auto",
                      data: { turbo_submits_with: t("mfa.totp_enrollment.submit_loading") } %>
    <% end %>
  <% end %>
</div>
