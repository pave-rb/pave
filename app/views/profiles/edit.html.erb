<% content_for(:settings_sidebar) do %>
  <%= render "shared/account_settings_sidebar" %>
<% end %>

<% phone_locked = !current_user.super_admin? && current_user.space&.subscription&.trialing? %>

<div class="space-y-6">
  <%= render "shared/settings_intro",
             eyebrow: t("account.sidebar.eyebrow"),
             title: t("profiles.edit.title"),
             subtitle: t("profiles.edit.subtitle"),
             statuses: [
               settings_intro_status(User.human_attribute_name(:email), @user.email, tone: :neutral),
               settings_intro_status(t("profiles.security.title"), account_security_summary(@user), tone: (@user.mfa_enabled? ? :success : :warning))
             ] %>

  <%= form_with model: @user, url: profile_path, method: :patch, class: "space-y-6" do |form| %>
    <%= render "shared/error_messages", resource: @user %>

    <%= render "shared/settings_panel",
               title: t("profiles.edit.identity_title"),
               description: t("profiles.edit.identity_description") do %>
      <div class="settings-info-tile mb-4"
           data-controller="image-upload-preview"
           data-image-upload-preview-selected-message-value="<%= t("profiles.edit.profile_picture_selected", filename: "%{filename}") %>">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center">
          <div class="h-20 w-20 overflow-hidden rounded-full border border-slate-200 bg-slate-100">
            <%= tag.img src: (@user.profile_picture_file.present? ? profile_picture_path : nil),
                        alt: t("profiles.edit.profile_picture_alt", name: @user.name.presence || @user.email),
                        class: "h-full w-full object-cover #{@user.profile_picture_file.present? ? "" : "hidden"}",
                        data: {
                          role: "profile-picture-preview-image",
                          image_upload_preview_target: "previewImage"
                        } %>
            <div class="flex h-full w-full items-center justify-center text-slate-400 <%= @user.profile_picture_file.present? ? "hidden" : "" %>"
                 data-role="profile-picture-placeholder"
                 data-image-upload-preview-target="placeholder">
              <%= render "shared/icons/user_circle", class: "h-10 w-10" %>
            </div>
          </div>

          <div class="min-w-0 flex-1 space-y-3">
            <div>
              <%= form.label :profile_picture_upload, t("profiles.edit.profile_picture_label"), class: form_label_classes %>
              <%= form.file_field :profile_picture_upload,
                                  accept: "image/png,image/jpeg,image/webp",
                                  class: "mt-2 block w-full text-sm text-slate-600 file:mr-3 file:rounded-md file:border-0 file:bg-slate-900 file:px-3 file:py-2 file:text-sm file:font-medium file:text-white hover:file:bg-slate-800",
                                  data: {
                                    action: "change->image-upload-preview#update",
                                    image_upload_preview_target: "input"
                                  } %>
              <p class="mt-1.5 text-xs text-slate-500"><%= t("profiles.edit.profile_picture_hint") %></p>
              <p class="mt-1.5 min-h-5 text-xs font-medium text-slate-600"
                 data-role="profile-picture-selection-feedback"
                 data-image-upload-preview-target="status"
                 aria-live="polite"></p>
            </div>

            <% if @user.profile_picture_file.present? %>
              <%= link_to t("profiles.edit.profile_picture_remove"),
                          profile_picture_path,
                          class: "#{button_classes(:secondary)} w-full justify-center sm:w-auto",
                          data: {
                            turbo_method: :delete,
                            turbo_confirm: t("profiles.edit.profile_picture_remove_confirm")
                          } %>
            <% end %>
          </div>
        </div>
      </div>

      <div class="grid gap-4 lg:grid-cols-2">
        <div>
          <%= form.label :name, class: form_label_classes %>
          <%= form.text_field :name, class: form_input_classes %>
        </div>

        <div>
          <%= label_tag :user_email, User.human_attribute_name(:email), class: form_label_classes %>
          <%= email_field_tag :user_email,
                              @user.email,
                              class: form_input_classes("bg-slate-50 text-slate-500"),
                              readonly: true,
                              disabled: true %>
          <p class="mt-1.5 text-xs text-slate-500"><%= t("profiles.edit.email_hint") %></p>
        </div>
      </div>

      <div class="grid gap-4 lg:grid-cols-2">
        <div>
          <%= form.label :phone_number, t("profiles.edit.phone_label"), class: form_label_classes %>
          <%= form.telephone_field :phone_number,
                                   disabled: phone_locked,
                                   class: form_input_classes(phone_locked ? "bg-slate-100 cursor-not-allowed" : nil) %>
          <% if phone_locked %>
            <p class="mt-1.5 text-xs text-slate-500"><%= t("profiles.edit.phone_locked_during_trial") %></p>
          <% end %>
        </div>

        <%= render "shared/settings_link_card",
                   path: profile_security_path,
                   title: t("profiles.security.title"),
                   description: t("profiles.edit.security_card_description"),
                   summary: account_security_summary(@user),
                   badge: linked_identity_summary(@user) %>
      </div>
    <% end %>

    <%= render "shared/settings_action_bar", reveal_mode: :dirty do %>
      <%= form.submit t("profiles.edit.submit"),
                      class: "#{button_classes(:primary)} w-full justify-center lg:w-auto",
                      data: { turbo_submits_with: t("shared.submitting") } %>
    <% end %>
  <% end %>

  <%= render "shared/settings_panel",
             title: t("profiles.edit.export_title"),
             description: t("profiles.edit.export_body") do %>
    <%= button_to t("profiles.edit.export_action"),
                  request_data_export_profile_path,
                  method: :post,
                  class: "#{button_classes(:secondary)} w-full justify-center lg:w-auto",
                  data: {
                    turbo_confirm: t("profiles.edit.export_confirm"),
                    turbo_submits_with: t("shared.submitting")
                  } %>
  <% end %>

  <%= render "shared/settings_panel",
             title: t("profiles.edit.deletion_title"),
             description: t("profiles.edit.deletion_body") do %>
    <div class="space-y-5">
      <% if @active_deletion_request %>
        <div class="rounded-2xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900">
          <p class="font-medium"><%= t("profiles.edit.deletion_pending_title") %></p>
          <p class="mt-1"><%= t("profiles.edit.deletion_pending_body", scheduled_for: l(@active_deletion_request.scheduled_for, format: :long)) %></p>
        </div>

        <%= button_to t("profiles.edit.cancel_deletion_action"),
                      cancel_deletion_request_profile_path,
                      method: :delete,
                      class: "#{button_classes(:secondary)} w-full justify-center lg:w-auto",
                      data: {
                        turbo_confirm: t("profiles.edit.cancel_deletion_confirm"),
                        turbo_submits_with: t("shared.removing")
                      } %>
      <% else %>
        <%= button_to t("profiles.edit.request_deletion_action"),
                      request_deletion_profile_path,
                      method: :post,
                      class: "#{button_classes(:danger)} w-full justify-center lg:w-auto",
                      data: {
                        turbo_confirm: t("profiles.edit.request_deletion_confirm"),
                        turbo_submits_with: t("shared.deleting")
                      } %>
      <% end %>
    </div>
  <% end %>
</div>
