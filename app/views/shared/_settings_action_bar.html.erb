<%
  reveal_mode = local_assigns.fetch(:reveal_mode, :always).to_s
  hidden_by_default = reveal_mode == "dirty"
%>

<div data-role="settings-action-bar"
     data-controller="settings-action-bar"
     data-settings-action-bar-reveal-mode-value="<%= reveal_mode %>"
     data-settings-action-bar-success-message-value="<%= t("shared.action_bar.saved") %>"
     data-settings-action-bar-error-message-value="<%= t("shared.action_bar.failed") %>"
     class="settings-action-bar-floating fixed left-3 z-20 md:sticky md:bottom-4 md:left-auto md:px-0 md:pb-0 <%= "hidden" if hidden_by_default %>">
  <div data-role="settings-action-bar-panel"
       data-settings-action-bar-target="panel"
       class="settings-action-bar-panel">
    <div class="settings-action-bar-layout">
      <div class="settings-action-bar-copy">
        <% if local_assigns[:hint].present? %>
          <p class="hidden text-sm text-slate-500 md:block"
             data-settings-action-bar-target="hint"><%= hint %></p>
        <% end %>
        <p class="settings-action-bar-status hidden"
           data-role="settings-action-bar-status"
           data-settings-action-bar-target="status"
           aria-live="polite"></p>
      </div>
      <div class="settings-action-bar-buttons">
        <%= yield %>
      </div>
    </div>
  </div>
</div>
