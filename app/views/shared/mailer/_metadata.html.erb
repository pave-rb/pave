<table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
       style="margin: 20px 0 0; border-collapse: separate; background: <%= email_theme[:background] %>; border: 1px solid <%= email_theme[:border] %>; border-radius: 12px;">
  <% rows.each_with_index do |row, index| %>
    <tr>
      <td style="padding: 14px 18px; border-bottom: <%= index == rows.length - 1 ? 'none' : "1px solid #{email_theme[:border]}" %>;">
        <div style="margin: 0 0 4px; font-family: Inter, Arial, Helvetica, sans-serif; font-size: 12px; line-height: 16px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; color: <%= email_theme[:subtle] %>;">
          <%= row[:label] %>
        </div>
        <div style="font-family: Inter, Arial, Helvetica, sans-serif; font-size: 16px; line-height: 24px; color: <%= email_theme[:text] %>;">
          <%= row[:value] %>
        </div>
      </td>
    </tr>
  <% end %>
</table>
