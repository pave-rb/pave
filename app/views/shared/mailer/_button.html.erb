<table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin: 0;">
  <tr>
    <td align="center" bgcolor="<%= email_theme[:cta] %>" style="border-radius: 8px;">
      <a href="<%= url %>"
         style="display: inline-block; padding: 13px 22px; font-family: Inter, Arial, Helvetica, sans-serif; font-size: 16px; font-weight: 600; line-height: 20px; color: <%= email_theme[:cta_text] %>; text-decoration: none; border-radius: 8px;">
        <%= label %>
      </a>
    </td>
  </tr>
</table>
