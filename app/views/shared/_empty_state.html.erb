<div class="rounded-card border border-dashed border-slate-300 bg-mist p-6 text-center text-sm text-slate-600">
  <div><%= content %></div>
  <% if local_assigns[:cta_path].present? && local_assigns[:cta_text].present? %>
    <div class="mt-4">
      <%= link_to cta_text, cta_path, class: button_classes(:primary), data: local_assigns[:cta_data] || {} %>
    </div>
  <% end %>
</div>
