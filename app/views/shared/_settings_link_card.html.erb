<%= link_to path, class: "group block rounded-[1.4rem] border border-slate-200/80 bg-white/90 p-4 shadow-sm shadow-slate-200/40 transition hover:-translate-y-0.5 hover:border-electric/20 hover:shadow-md focus:outline-none focus:ring-2 focus:ring-electric/30" do %>
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0 space-y-1">
      <div class="flex items-center gap-2">
        <h3 class="text-sm font-semibold text-deep"><%= title %></h3>
        <% if local_assigns[:badge].present? %>
          <span class="inline-flex items-center rounded-full border border-white/60 bg-slate-50 px-2 py-0.5 text-[11px] font-medium uppercase tracking-wide text-slate-500"><%= badge %></span>
        <% end %>
      </div>
      <% if local_assigns[:description].present? %>
        <p class="text-sm leading-6 text-slate-600"><%= description %></p>
      <% end %>
      <% if local_assigns[:summary].present? %>
        <p class="text-sm font-medium text-slate-800"><%= summary %></p>
      <% end %>
    </div>

    <span class="mt-1 inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-slate-200 bg-slate-50 text-slate-400 transition group-hover:border-electric/20 group-hover:bg-electric/10 group-hover:text-electric" aria-hidden="true">
      ›
    </span>
  </div>
<% end %>
