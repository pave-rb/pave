<div id="dock"
     class="contents"
     data-turbo-permanent>
  <nav class="fixed z-50 glass-frosty rounded-[2rem] dock-bottom-safe
              inset-x-3 py-2 px-2
              sm:z-40 sm:inset-x-auto sm:right-4 sm:bottom-auto sm:top-1/2 sm:-translate-y-1/2 sm:py-4 sm:px-3">
    <div class="flex items-center justify-around w-full sm:flex-col sm:w-auto sm:justify-start sm:gap-1.5">
      <%= link_to root_path,
                  class: "flex flex-col items-center justify-center gap-0.5 w-14 h-14 rounded-2xl hover:bg-slate-100/60 transition-colors #{nav_group_active?(:dashboard) ? 'text-electric' : 'text-slate-400'}",
                  aria: { label: "Home" } do %>
        <%= image_tag app_logo_asset, class: "w-6 h-6 sm:w-10 sm:h-10 rounded-md sm:rounded-xl object-contain", alt: app_name %>
        <span class="text-[10px] font-medium sm:hidden">Home</span>
      <% end %>

      <% if current_tenant.present? %>
        <%= link_to users_path,
                    class: "flex flex-col items-center justify-center gap-0.5 w-14 h-14 rounded-2xl transition-colors #{nav_active?(:team) ? 'bg-electric/15 text-electric' : 'text-slate-400 hover:text-deep hover:bg-slate-100/60'}",
                    aria: { label: t("layout.nav.team") } do %>
          <%= render "shared/icons/building_office", class: "h-5 w-5 sm:h-[30px] sm:w-[30px]" %>
          <span class="text-[10px] font-medium sm:hidden"><%= t("layout.nav.team") %></span>
        <% end %>
      <% end %>

      <div class="hidden sm:block w-12 h-px my-0.5 bg-deep/8"></div>

      <%= link_to edit_profile_path,
                  class: "flex flex-col items-center justify-center gap-0.5 w-14 h-14 rounded-2xl transition-colors #{nav_group_active?(:profile) ? 'bg-electric/15 text-electric' : 'text-slate-400 hover:text-deep hover:bg-slate-100/60'}",
                  aria: { label: t("layout.nav.profile") } do %>
        <%= render "shared/icons/user_circle", class: "h-5 w-5 sm:h-[30px] sm:w-[30px]" %>
        <span class="text-[10px] font-medium sm:hidden"><%= t("layout.nav.profile") %></span>
      <% end %>
    </div>
  </nav>
</div>
