<nav aria-label="<%= t("settings.sidebar.label") %>" data-role="settings-sidebar" class="settings-sidebar-rail sticky-filter space-y-4 min-w-0">
  <div class="settings-sidebar-mobile md:hidden">
    <div class="settings-sidebar__scroller">
      <ul class="flex min-w-max gap-2">
        <% settings_navigation_groups.each do |group| %>
          <% group[:items].each do |label, path, section| %>
            <%= settings_sidebar_link label, path, section, variant: :mobile %>
          <% end %>
        <% end %>
      </ul>
    </div>
  </div>

  <div class="settings-sidebar-desktop hidden md:block md:w-full">
    <div data-role="settings-sidebar-card" class="settings-sidebar__panel">
      <div class="mb-3 px-3 pt-2">
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500"><%= t("settings.sidebar.eyebrow") %></p>
        <p class="mt-2 text-sm leading-6 text-slate-600"><%= t("settings.sidebar.subtitle") %></p>
      </div>

      <div class="space-y-4" data-role="settings-navigation">
        <% settings_navigation_groups.each do |group| %>
          <section class="space-y-2">
            <h2 class="px-3 text-[11px] font-semibold uppercase tracking-[0.24em] text-slate-400"><%= group[:title] %></h2>
            <ul class="space-y-1">
              <% group[:items].each do |label, path, section| %>
                <%= settings_sidebar_link label, path, section %>
              <% end %>
            </ul>
          </section>
        <% end %>
      </div>
    </div>
  </div>
</nav>
