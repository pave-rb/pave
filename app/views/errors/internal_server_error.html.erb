<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= t("errors.internal_server_error.title") %></title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="robots" content="noindex,nofollow">
    <%= csrf_meta_tags %>
    <%= stylesheet_link_tag "application", "tailwind", "data-turbo-track": "reload" %>
  </head>
  <body class="grid min-h-screen place-items-center bg-slate-50 p-6 text-deep">
    <main class="w-full max-w-lg rounded-lg border border-slate-300 bg-white p-8">
      <h1 class="mb-3 text-[1.75rem] leading-tight font-bold text-deep"><%= t("errors.internal_server_error.heading") %></h1>
      <p class="mb-3 leading-7 text-slate-700"><%= t("errors.internal_server_error.message") %></p>
      <p class="leading-7 text-slate-700"><%= t("errors.internal_server_error.reference", request_id: request_id) %></p>
    </main>
  </body>
</html>
