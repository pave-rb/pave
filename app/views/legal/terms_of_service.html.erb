  <h1 class="font-display text-3xl font-extrabold text-deep tracking-tight">Termos de Uso</h1>
  <p class="mt-2 text-sm text-slate-500">
    <%= t("legal.terms_of_service.last_updated", date: l(@document.published_at.to_date)) %>
    |
    <%= t("legal.version", version: @document.version) %>
