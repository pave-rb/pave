<% content_for(:settings_sidebar) do %>
  <%= render "shared/account_settings_sidebar" %>
<% end %>

<div class="space-y-6">
  <%= render "shared/settings_intro",
             eyebrow: t("account.sidebar.eyebrow"),
             title: t("preferences.edit.title"),
             subtitle: t("preferences.edit.subtitle"),
             statuses: [
               settings_intro_status(t("preferences.edit.locale_label"), profile_locale_label(@user_preference), tone: :accent),
               settings_intro_status(
                 t("preferences.edit.push_notifications_status_label"),
                 @user_preference.push_notifications_enabled? ? t("preferences.edit.push_notifications_enabled") : t("preferences.edit.push_notifications_disabled"),
                 tone: @user_preference.push_notifications_enabled? ? :success : :neutral
               )
             ] %>

  <%= form_with model: @user_preference, url: preferences_path, method: :patch, class: "space-y-6" do |form| %>
    <%= render "shared/error_messages", resource: @user_preference %>

    <%= render "shared/settings_panel",
               title: t("preferences.edit.language_title"),
               description: t("preferences.edit.language_description") do %>
      <div class="max-w-xl">
        <%= form.label :locale, t("preferences.edit.locale_label"), class: form_label_classes %>
        <%= form.select :locale,
                        I18n.available_locales.map { |locale| [ t("layout.nav.language.#{locale == :'pt-BR' ? :pt : locale}"), locale.to_s ] },
                        {},
                        class: form_input_classes %>
      </div>
    <% end %>

    <%= render "shared/settings_panel",
               title: t("preferences.edit.push_notifications_title"),
               description: t("preferences.edit.push_notifications_description") do %>
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div class="space-y-1">
          <p class="text-sm font-medium text-deep"><%= t("preferences.edit.push_notifications_status_label") %></p>
          <p class="text-sm text-slate-500"
             data-push-notifications-target="status"
             data-push-notifications-enabled-label="<%= t("preferences.edit.push_notifications_enabled") %>"
             data-push-notifications-disabled-label="<%= t("preferences.edit.push_notifications_disabled") %>"
             data-push-notifications-denied-label="<%= t("preferences.edit.push_notifications_denied") %>"
             data-push-notifications-pending-label="<%= t("preferences.edit.push_notifications_pending") %>">
            <% if @user_preference.push_notifications_permission == "denied" %>
              <%= t("preferences.edit.push_notifications_denied") %>
            <% elsif @user_preference.push_notifications_enabled? %>
              <%= t("preferences.edit.push_notifications_enabled") %>
            <% else %>
              <%= t("preferences.edit.push_notifications_disabled") %>
            <% end %>
          </p>
        </div>

        <div class="flex flex-col gap-2 sm:flex-row">
          <%= button_tag t("preferences.edit.push_notifications_turn_on"),
                         type: "button",
                         class: "#{button_classes(:primary)} justify-center",
                         disabled: !Notifications::PushConfiguration.configured?,
                         data: {
                           action: "push-notifications#enable",
                           push_notifications_target: "enableButton"
                         } %>
          <%= button_tag t("preferences.edit.push_notifications_turn_off"),
                         type: "button",
                         class: "#{button_classes(:secondary)} justify-center",
                         disabled: !@user_preference.push_notifications_enabled?,
                         data: {
                           action: "push-notifications#disable",
                           push_notifications_target: "disableButton"
                         } %>
        </div>
      </div>

      <% unless Notifications::PushConfiguration.configured? %>
        <p class="mt-3 text-xs text-slate-500"><%= t("preferences.edit.push_notifications_unavailable") %></p>
      <% end %>
    <% end %>

    <%= render "shared/settings_action_bar", reveal_mode: :dirty do %>
      <%= form.submit t("preferences.edit.submit"),
                      class: "#{button_classes(:primary)} w-full justify-center lg:w-auto",
                      data: { turbo_submits_with: t("shared.submitting") } %>
    <% end %>
  <% end %>
</div>
