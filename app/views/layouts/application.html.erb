<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= content_for(:title) || app_name %></title>
    <%= render "layouts/pwa_head" %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@500&family=Plus+Jakarta+Sans:wght@700;800&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "application", *Pave.products.stylesheets, "flatpickr", "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <% push_notifications_public_key = user_signed_in? ? Notifications::PushConfiguration.vapid_public_key : nil %>
  <% push_notifications_enabled = user_signed_in? && current_user.user_preference&.push_notifications_enabled? %>
  <body class="app-shell min-h-screen flex flex-col overflow-x-clip text-deep"
        <% if user_signed_in? %>
        data-controller="push-notifications"
        data-push-notifications-public-key-value="<%= push_notifications_public_key.to_s %>"
        data-push-notifications-enabled-value="<%= push_notifications_enabled %>"
        data-push-notifications-create-path-value="<%= push_subscriptions_path %>"
        data-push-notifications-destroy-path-value="<%= push_subscription_path %>"
        data-push-notifications-preference-path-value="<%= push_notification_preference_path %>"
        <% end %>
        data-confirm-title="<%= t('shared.confirm_modal.title') %>"
        data-confirm-label="<%= t('shared.confirm_modal.confirm') %>"
        data-cancel-label="<%= t('shared.confirm_modal.cancel') %>">
    <%= render "shared/email_confirmation_banner" if user_signed_in? && !current_user.confirmed? %>
    <% if user_signed_in? %>
      <% if impersonating? %>
        <div class="flex items-center justify-center gap-3 bg-amber-500 px-4 py-2 text-sm font-medium text-amber-900">
          <span><%= t("backoffice.impersonation.banner", name: current_user.name.presence || current_user.email) %></span>
          <%= button_to t("backoffice.impersonation.stop"),
                        backoffice_stop_impersonation_path,
                        method: :post,
                        class: "inline-flex rounded-md bg-amber-600 px-2 py-1 text-xs font-semibold text-amber-900 hover:bg-amber-700" %>
        </div>
      <% end %>
      <% if current_user.super_admin? %>
        <% show_backoffice_product_nav = controller_path != "backoffice/products" %>
        <nav data-controller="dropdown" data-action="click@window->dropdown#close" class="bg-deep border-b border-slate-800">
          <div class="mx-auto max-w-8xl px-4 sm:px-6 lg:px-8">
            <div class="flex h-14 items-center justify-between">
              <div class="flex items-center gap-4">
                <%= link_to app_name, backoffice_root_path, class: "font-display font-bold text-sm text-white tracking-tight" %>
                <% if show_backoffice_product_nav %>
                  <div class="hidden md:flex items-center gap-3 text-sm">
                    <%= link_to t("layout.nav.tenants"), backoffice_spaces_path, class: "text-slate-200 hover:text-white px-2 py-1 rounded-md hover:bg-slate-800 transition" %>
                    <%= link_to t("layout.nav.backoffice_users"), backoffice_users_path, class: "text-slate-200 hover:text-white px-2 py-1 rounded-md hover:bg-slate-800 transition" %>
                    <%= link_to t("layout.nav.backoffice_billing"), backoffice_billing_index_path, class: "text-slate-200 hover:text-white px-2 py-1 rounded-md hover:bg-slate-800 transition" %>
                    <%= link_to t("layout.nav.backoffice_audit_logs"), backoffice_audit_logs_path, class: "text-slate-200 hover:text-white px-2 py-1 rounded-md hover:bg-slate-800 transition" %>
                    <%= link_to t("layout.nav.backoffice_logs"), backoffice_logs_path, class: "text-slate-200 hover:text-white px-2 py-1 rounded-md hover:bg-slate-800 transition" %>
                    <%= link_to t("layout.nav.backoffice_plans"), backoffice_plans_path, class: "text-slate-200 hover:text-white px-2 py-1 rounded-md hover:bg-slate-800 transition" %>
                    <%= link_to t("layout.nav.backoffice_coupons"), backoffice_coupons_path, class: "text-slate-200 hover:text-white px-2 py-1 rounded-md hover:bg-slate-800 transition" %>
                    <%= link_to t("layout.nav.backoffice_credit_bundles"), backoffice_credit_bundles_path, class: "text-slate-200 hover:text-white px-2 py-1 rounded-md hover:bg-slate-800 transition" %>
                    <%= link_to t("layout.nav.backoffice_integrations"), backoffice_integrations_path, class: "text-slate-200 hover:text-white px-2 py-1 rounded-md hover:bg-slate-800 transition" %>
                    <%= link_to t("layout.nav.backoffice_registrations"), backoffice_registrations_path, class: "text-slate-200 hover:text-white px-2 py-1 rounded-md hover:bg-slate-800 transition" %>
                    <%= link_to t("layout.nav.backoffice_backups"), backoffice_backups_path, class: "text-slate-200 hover:text-white px-2 py-1 rounded-md hover:bg-slate-800 transition" %>
                  </div>
                <% end %>
              </div>
              <div class="hidden md:flex items-center gap-2">
                <div class="relative" data-controller="dropdown" data-action="click@window->dropdown#close">
                  <button type="button"
                          class="inline-flex items-center justify-center rounded-full bg-slate-800 p-2 text-slate-200 hover:bg-slate-700 hover:text-white focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-slate-900"
                          data-action="dropdown#toggle"
                          aria-haspopup="true"
                          aria-label="<%= t('layout.nav.profile') %>">
                    <%= render "shared/icons/user" %>
                  </button>
                  <div data-dropdown-target="menu"
                       class="hidden absolute right-0 top-full z-50 mt-2 min-w-[200px] rounded-md bg-slate-800 py-1 shadow-lg ring-1 ring-slate-700">
                    <div class="border-b border-slate-700 px-3 py-2">
                      <p class="text-xs font-medium text-white truncate"><%= current_user.name.presence || current_user.email %></p>
                      <p class="text-xs text-slate-400 truncate"><%= current_user.email %></p>
                    </div>
                    <%= link_to edit_profile_path, class: "block px-3 py-2 text-sm text-slate-200 hover:bg-slate-700 hover:text-white" do %>
                      <%= t("layout.nav.profile") %>
                    <% end %>
                    <%= link_to edit_preferences_path, class: "block px-3 py-2 text-sm text-slate-200 hover:bg-slate-700 hover:text-white" do %>
                      <%= t("layout.nav.preferences") %>
                    <% end %>
                    <div class="border-t border-slate-700">
                      <%= button_to t("layout.nav.logout"),
                                    destroy_user_session_path,
                                    method: :delete,
                                    data: { turbo: false },
                                    class: "block w-full px-3 py-2 text-left text-sm text-slate-200 hover:bg-slate-700 hover:text-white" %>
                    </div>
                  </div>
                </div>
              </div>
              <div class="flex items-center md:hidden">
                <button type="button"
                        class="inline-flex items-center justify-center rounded-md p-1.5 text-slate-200 hover:bg-slate-800 hover:text-white focus:outline-none focus:ring-2 focus:ring-white"
                        data-action="dropdown#toggle"
                        aria-label="Toggle navigation"
                        aria-haspopup="true">
                  <span data-dropdown-target="openIcon"><%= render "shared/icons/menu" %></span>
                  <span data-dropdown-target="closeIcon" class="hidden"><%= render "shared/icons/close" %></span>
                </button>
              </div>
            </div>
            <div class="md:hidden hidden" data-dropdown-target="menu">
              <div class="space-y-1 pb-3 pt-2">
                <% if show_backoffice_product_nav %>
                  <%= link_to t("layout.nav.tenants"), backoffice_spaces_path, class: "block rounded-md px-3 py-2 text-sm font-medium text-slate-100 hover:bg-slate-800" %>
                  <%= link_to t("layout.nav.backoffice_users"), backoffice_users_path, class: "block rounded-md px-3 py-2 text-sm font-medium text-slate-100 hover:bg-slate-800" %>
                  <%= link_to t("layout.nav.backoffice_billing"), backoffice_billing_index_path, class: "block rounded-md px-3 py-2 text-sm font-medium text-slate-100 hover:bg-slate-800" %>
                  <%= link_to t("layout.nav.backoffice_audit_logs"), backoffice_audit_logs_path, class: "block rounded-md px-3 py-2 text-sm font-medium text-slate-100 hover:bg-slate-800" %>
                  <%= link_to t("layout.nav.backoffice_logs"), backoffice_logs_path, class: "block rounded-md px-3 py-2 text-sm font-medium text-slate-100 hover:bg-slate-800" %>
                  <%= link_to t("layout.nav.backoffice_plans"), backoffice_plans_path, class: "block rounded-md px-3 py-2 text-sm font-medium text-slate-100 hover:bg-slate-800" %>
                  <%= link_to t("layout.nav.backoffice_coupons"), backoffice_coupons_path, class: "block rounded-md px-3 py-2 text-sm font-medium text-slate-100 hover:bg-slate-800" %>
                  <%= link_to t("layout.nav.backoffice_credit_bundles"), backoffice_credit_bundles_path, class: "block rounded-md px-3 py-2 text-sm font-medium text-slate-100 hover:bg-slate-800" %>
                  <%= link_to t("layout.nav.backoffice_integrations"), backoffice_integrations_path, class: "block rounded-md px-3 py-2 text-sm font-medium text-slate-100 hover:bg-slate-800" %>
                  <%= link_to t("layout.nav.backoffice_registrations"), backoffice_registrations_path, class: "block rounded-md px-3 py-2 text-sm font-medium text-slate-100 hover:bg-slate-800" %>
                  <%= link_to t("layout.nav.backoffice_backups"), backoffice_backups_path, class: "block rounded-md px-3 py-2 text-sm font-medium text-slate-100 hover:bg-slate-800" %>
                <% end %>
                <div class="border-t border-slate-800 mt-2 pt-2 space-y-1 px-3 pb-2">
                  <%= link_to edit_profile_path, class: "block rounded-md px-3 py-2 text-sm font-medium text-slate-100 hover:bg-slate-800" do %>
                    <%= t("layout.nav.profile") %>
                  <% end %>
                  <%= link_to edit_preferences_path, class: "block rounded-md px-3 py-2 text-sm font-medium text-slate-100 hover:bg-slate-800" do %>
                    <%= t("layout.nav.preferences") %>
                  <% end %>
                  <%= button_to t("layout.nav.logout"),
                                destroy_user_session_path,
                                method: :delete,
                                data: { turbo: false },
                                class: "block w-full text-left rounded-md px-3 py-2 text-sm font-medium text-slate-100 hover:bg-slate-800" %>
                </div>
              </div>
            </div>
          </div>
        </nav>
      <% elsif tenant_staff? %>
        <%= turbo_stream_from [current_tenant, :app] %>
        <% hide_mobile_dock = !!@hide_mobile_dock %>
        <div id="dock_visibility"
             class="<%= hide_mobile_dock ? 'hidden sm:contents' : 'contents' %>"
             data-mobile-dock-hidden="<%= hide_mobile_dock %>">
          <%= render tenant_dock_partial %>
        </div>
      <% end %>
    <% end %>

    <%= render "shared/billing_banner" %>

    <div id="flash_messages">
      <%= render "shared/flash_messages" %>
    </div>

    <div id="modal_container"></div>
    <turbo-frame id="finish_modal"></turbo-frame>

    <% if @use_inbox_layout %>
      <div class="mobile-dock-scroll-end flex flex-1 min-h-0 min-w-0 w-full max-w-full overflow-x-clip overflow-y-hidden sm:mx-auto sm:max-w-[80rem] sm:pb-0 sm:pr-28">
        <%= yield %>
      </div>
    <% elsif content_for?(:settings_sidebar) %>
      <main class="mobile-bottom-stack-scroll-end mx-auto w-full max-w-7xl px-4 pt-6 sm:py-8 sm:pb-8 sm:pr-28">
        <div data-role="settings-shell" class="settings-shell">
          <%= yield(:settings_sidebar) %>
          <div class="settings-shell-content">
            <%= yield %>
          </div>
        </div>
      </main>
    <% else %>
      <main class="mobile-dock-scroll-end mx-auto px-4 pt-8 sm:pb-8 sm:pr-28 <%= content_for?(:wide_layout) ? 'max-w-8xl' : 'max-w-6xl' %>">
        <%= yield %>
      </main>
    <% end %>
  </body>
</html>
