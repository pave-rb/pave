<% price = number_to_currency(@new_plan.price_cents / 100.0, unit: "R$", separator: ",", delimiter: ".") %>
<% content_for :email_preheader, t("billing.subscription_mailer.plan_change_payment_reminder.body_#{@payment_method}", plan_name: @new_plan.name, price: price) %>
<% content_for :email_eyebrow, t("mailers.shared.eyebrows.billing") %>
<% content_for :email_title, message.subject %>
<% content_for :email_intro, t("billing.subscription_mailer.plan_change_payment_reminder.intro") %>

<p style="margin: 0 0 16px;"><%= email_greeting(@space.name) %></p>

<%= render "shared/mailer/callout",
           title: t("billing.subscription_mailer.plan_change_payment_reminder.callout_title"),
           tone: "warning",
           content: t("billing.subscription_mailer.plan_change_payment_reminder.body_#{@payment_method}",
                      plan_name: @new_plan.name,
                      price: price) %>

<%= render "shared/mailer/metadata", rows: [
  { label: t("billing.subscription_mailer.plan_change_payment_reminder.metadata.plan_name"), value: @new_plan.name },
  { label: t("billing.subscription_mailer.plan_change_payment_reminder.metadata.price"), value: price },
  { label: t("billing.subscription_mailer.plan_change_payment_reminder.metadata.payment_method"), value: t("billing.payment_methods.#{@payment_method}") }
] %>
