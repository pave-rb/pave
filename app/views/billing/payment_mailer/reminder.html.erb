<%
  amount = number_to_currency(@amount, unit: "R$", separator: ",", delimiter: ".")
  due_date = @due_date ? I18n.l(@due_date, format: :long) : "-"
  callout_title =
    case @reminder_type.to_s
    when "overdue" then t("billing.payment_mailer.reminder.callout_titles.overdue")
    when "due_today" then t("billing.payment_mailer.reminder.callout_titles.due_today")
    else t("billing.payment_mailer.reminder.callout_titles.default")
    end
  tone =
    case @reminder_type.to_s
    when "overdue" then "danger"
    when "due_today" then "warning"
    else "info"
    end
%>
<% content_for :email_preheader, t("billing.payment_mailer.reminder.body_#{@reminder_type}_#{@payment_method}", amount: amount, due_date: due_date) %>
<% content_for :email_eyebrow, t("mailers.shared.eyebrows.billing") %>
<% content_for :email_title, message.subject %>
<% content_for :email_intro, t("billing.payment_mailer.reminder.intro") %>
<% content_for(:email_cta_label, t("billing.payment_mailer.reminder.pay_now")) if @invoice_url.present? %>
<% content_for(:email_cta_url, @invoice_url) if @invoice_url.present? %>

<p style="margin: 0 0 16px;"><%= email_greeting(@space.name) %></p>

<%= render "shared/mailer/callout",
           title: callout_title,
           tone: tone,
           content: t("billing.payment_mailer.reminder.body_#{@reminder_type}_#{@payment_method}",
                      amount: amount,
                      due_date: due_date) %>

<%= render "shared/mailer/metadata", rows: [
  { label: t("billing.payment_mailer.reminder.metadata.amount"), value: amount },
  { label: t("billing.payment_mailer.reminder.metadata.due_date"), value: due_date },
  { label: t("billing.payment_mailer.reminder.metadata.payment_method"), value: t("billing.payment_methods.#{@payment_method}") }
] %>
