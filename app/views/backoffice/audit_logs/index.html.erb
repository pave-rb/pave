<div class="space-y-4">
  <%= render "shared/page_header",
             title: t("backoffice.audit_logs.index.title"),
             subtitle: t("backoffice.audit_logs.index.subtitle") %>

  <div class="card-glass p-4">
    <%= form_with url: backoffice_audit_logs_path, method: :get, class: "grid gap-3 md:grid-cols-4" do |form| %>
      <div>
        <%= form.label :query, t("backoffice.audit_logs.index.query"), class: "block text-xs font-semibold uppercase tracking-wide text-slate-500" %>
        <%= form.text_field :query, value: params[:query], placeholder: t("backoffice.audit_logs.index.query_placeholder"), class: "mt-1 block w-full rounded-md border-slate-300 text-sm shadow-sm focus:border-slate-500 focus:ring-slate-500" %>
      </div>
      <div>
        <%= form.label :event_type, t("backoffice.audit_logs.index.event_type"), class: "block text-xs font-semibold uppercase tracking-wide text-slate-500" %>
        <%= form.select :event_type, options_for_select([[t("backoffice.audit_logs.index.all_events"), ""]] + @event_types.map { |event_type| [event_type, event_type] }, params[:event_type]), {}, class: "mt-1 block w-full rounded-md border-slate-300 text-sm shadow-sm focus:border-slate-500 focus:ring-slate-500" %>
      </div>
      <div>
        <%= form.label :space_id, t("backoffice.audit_logs.index.space"), class: "block text-xs font-semibold uppercase tracking-wide text-slate-500" %>
        <%= form.select :space_id, options_for_select([[t("backoffice.audit_logs.index.all_spaces"), ""]] + @spaces.map { |space| [space.name, space.id] }, params[:space_id]), {}, class: "mt-1 block w-full rounded-md border-slate-300 text-sm shadow-sm focus:border-slate-500 focus:ring-slate-500" %>
      </div>
      <div class="flex items-end gap-2">
        <%= form.submit t("backoffice.audit_logs.index.filter"), class: button_classes(:primary) %>
        <%= link_to t("backoffice.audit_logs.index.clear"), backoffice_audit_logs_path, class: button_classes(:secondary) %>
      </div>
    <% end %>
  </div>

  <div class="card-glass overflow-hidden p-0">
    <% if @audit_logs.any? %>
      <table class="min-w-full divide-y divide-slate-200 text-sm">
        <thead class="bg-slate-50">
          <tr>
            <th scope="col" class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500"><%= t("backoffice.audit_logs.index.when") %></th>
            <th scope="col" class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500"><%= t("backoffice.audit_logs.index.event") %></th>
            <th scope="col" class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500"><%= t("backoffice.audit_logs.index.actor") %></th>
            <th scope="col" class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500"><%= t("backoffice.audit_logs.index.space") %></th>
            <th scope="col" class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500"><%= t("backoffice.audit_logs.index.subject") %></th>
            <th scope="col" class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wide text-slate-500"><%= t("backoffice.audit_logs.index.context") %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200 bg-white">
          <% @audit_logs.each do |log| %>
            <tr class="hover:bg-slate-50">
              <td class="px-4 py-2 text-xs text-slate-500"><%= l(log.created_at, format: :long) %></td>
              <td class="px-4 py-2 font-medium text-slate-900"><%= log.event_type %></td>
              <td class="px-4 py-2 text-slate-700">
                <% if log.actor %>
                  <div><%= log.actor.name.presence || "User ##{log.actor.id}" %></div>
                  <div class="text-xs text-slate-400"><%= log.actor.email %></div>
                <% else %>
                  <span class="text-xs text-slate-400"><%= t("backoffice.audit_logs.index.system_actor") %></span>
                <% end %>
              </td>
              <td class="px-4 py-2 text-slate-700"><%= log.space&.name || "—" %></td>
              <td class="px-4 py-2 text-slate-700"><%= log.subject_type.present? ? "#{log.subject_type} ##{log.subject_id}" : "—" %></td>
              <td class="px-4 py-2 text-xs text-slate-500">
                <div><%= log.metadata["controller"] || "—" %>#<%= log.metadata["action"] || "—" %></div>
                <div><%= log.ip_address || "—" %></div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
      <div class="px-4 py-3">
        <%= paginate @audit_logs %>
      </div>
    <% else %>
      <p class="px-5 py-4 text-sm text-slate-500"><%= t("backoffice.audit_logs.index.empty") %></p>
    <% end %>
  </div>
</div>
