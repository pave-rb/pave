<% enabled = @registration_setting.enabled? %>

<div class="space-y-6">
  <%= render "shared/page_header",
             title: t("backoffice.registrations.show.title"),
             subtitle: t("backoffice.registrations.show.subtitle") %>

  <div class="grid gap-4 lg:grid-cols-[1.4fr_1fr]">
    <div class="card-glass p-5">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div class="space-y-2">
          <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-semibold <%= enabled ? 'bg-emerald-50 text-emerald-700' : 'bg-amber-50 text-amber-700' %>">
            <%= enabled ? t("backoffice.registrations.show.status_enabled") : t("backoffice.registrations.show.status_disabled") %>
          </span>
          <h2 class="text-sm font-semibold text-slate-900"><%= t("backoffice.registrations.show.control_title") %></h2>
          <p class="max-w-2xl text-sm text-slate-600"><%= t("backoffice.registrations.show.control_body") %></p>
        </div>

        <div class="flex flex-wrap gap-2">
          <% if enabled %>
            <%= button_to t("backoffice.registrations.show.disable_button"),
                          backoffice_disable_registrations_path,
                          method: :patch,
                          class: button_classes(:danger),
                          data: { turbo_confirm: t("backoffice.registrations.show.disable_confirm") } %>
          <% else %>
            <%= button_to t("backoffice.registrations.show.enable_button"),
                          backoffice_enable_registrations_path,
                          method: :patch,
                          class: button_classes(:primary) %>
          <% end %>
        </div>
      </div>
    </div>

    <div class="card-glass p-5">
      <h2 class="text-sm font-semibold text-slate-900"><%= t("backoffice.registrations.show.scope_title") %></h2>
      <ul class="mt-4 list-disc space-y-2 pl-5 text-sm text-slate-600">
        <li><%= t("backoffice.registrations.show.scope_email") %></li>
        <li><%= t("backoffice.registrations.show.scope_social") %></li>
        <li><%= t("backoffice.registrations.show.scope_existing") %></li>
      </ul>
    </div>
  </div>
</div>
