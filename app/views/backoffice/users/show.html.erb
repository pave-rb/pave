<div class="space-y-6">
  <header class="flex items-center justify-between gap-3">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight text-slate-900">
        <%= t("backoffice.users.show.title") %>
      </h1>
      <p class="mt-1 text-xs text-slate-600">
        <%= t("backoffice.users.show.subtitle") %>
      </p>
    </div>
    <span class="inline-flex items-center rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-800">
      <%= @user.role.presence || "—" %><% if @user.super_admin? %> • <%= t("activerecord.attributes.user.system_role.super_admin") %><% end %>
    </span>
  </header>

  <div class="panel-card-compact">
    <dl class="detail-list">
      <div class="detail-list__row">
        <dt class="detail-list__term"><%= t("backoffice.users.show.email") %></dt>
        <dd class="detail-list__value"><%= @user.email %></dd>
      </div>
      <div class="detail-list__row">
        <dt class="detail-list__term"><%= t("backoffice.users.show.name") %></dt>
        <dd class="detail-list__value"><%= @user.name.presence || "—" %></dd>
      </div>
      <div class="detail-list__row">
        <dt class="detail-list__term"><%= t("backoffice.users.show.phone") %></dt>
        <dd class="detail-list__value"><%= @user.phone_number.presence || "—" %></dd>
      </div>
      <div class="detail-list__row">
        <dt class="detail-list__term"><%= t("backoffice.users.show.space") %></dt>
        <dd class="detail-list__value"><%= @user.space&.name || "—" %></dd>
      </div>
    </dl>
  </div>

  <div class="flex flex-wrap gap-3">
    <% unless @user.super_admin? %>
      <%= button_to t("backoffice.users.show.impersonate"),
                    impersonate_backoffice_user_path(@user),
                    method: :post,
                    class: button_classes(:cancel) %>
    <% end %>
    <%= link_to t("backoffice.users.show.edit"),
                edit_backoffice_user_path(@user, space_id: params[:space_id].presence),
                class: button_classes(:primary) %>
    <%= link_to t("backoffice.users.show.back"),
                backoffice_users_path(space_id: params[:space_id].presence),
                class: button_classes(:secondary) %>
    <%= button_to t("backoffice.users.show.delete"),
                  backoffice_user_path(@user),
                  method: :delete,
                  params: { space_id: params[:space_id].presence },
                  data: { turbo_confirm: t("backoffice.users.show.delete_confirm"), turbo_submits_with: t("shared.deleting") },
                  class: button_classes(:danger) %>
  </div>
</div>
