<div class="space-y-6">
  <header class="max-w-3xl">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-electric"><%= t("backoffice.products.index.eyebrow") %></p>
    <h1 class="mt-2 text-2xl font-semibold tracking-tight text-slate-900"><%= t("backoffice.products.index.title") %></h1>
    <p class="mt-2 text-sm text-slate-600"><%= t("backoffice.products.index.subtitle") %></p>
  </header>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    <% @products.each do |product| %>
      <%= link_to product.fetch(:path), class: "card group block p-5 transition hover:-translate-y-0.5 hover:border-electric/40 hover:shadow-lg" do %>
        <div class="flex items-start justify-between gap-4">
          <div>
            <h2 class="text-base font-semibold text-slate-900"><%= product.fetch(:name) %></h2>
            <p class="mt-2 text-sm leading-6 text-slate-600"><%= product.fetch(:description) %></p>
          </div>
          <span class="rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-semibold text-emerald-700"><%= product.fetch(:status) %></span>
        </div>

        <div class="mt-5 flex items-center text-sm font-semibold text-electric">
          <%= t("backoffice.products.index.open") %>
          <span class="ml-1 transition group-hover:translate-x-0.5">-&gt;</span>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
